{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student enrolled in the tailoring institute",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "course": { "type": "string" },
        "totalFee": { "type": "number" },
        "amountPaid": { "type": "number" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "course", "totalFee", "amountPaid", "balance"]
    },
    "Course": {
      "title": "Course",
      "description": "A course offered by the institute",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "duration": { "type": "string" },
        "fee": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "fee"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "method": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "amount", "type", "date"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "An item in the stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "totalQuantityBought": { "type": "number" },
        "quantityRemaining": { "type": "number" },
        "costPerItem": { "type": "number" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "totalQuantityBought", "quantityRemaining", "costPerItem", "totalCost"]
    },
    "InventoryTransaction": {
      "title": "InventoryTransaction",
      "description": "A transaction involving stock items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["usage", "sale"] },
        "quantity": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "profit": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "itemId", "type", "quantity", "date"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A tailoring customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Out for Delivery", "Received"] },
        "totalBill": { "type": "number" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "status", "totalBill", "balance"]
    },
    "Measurement": {
      "title": "Measurement",
      "description": "Tailoring measurements for a customer or student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string" },
        "unit": { "type": "string", "enum": ["in", "cm"] },
        "chest": { "type": "string" },
        "waist": { "type": "string" },
        "hip": { "type": "string" },
        "shoulder": { "type": "string" },
        "sleeveLength": { "type": "string" },
        "length": { "type": "string" },
        "neck": { "type": "string" },
        "inseam": { "type": "string" },
        "thigh": { "type": "string" },
        "customFields": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "value": { "type": "string" } } } },
        "specialInstructions": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "unit", "date"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a student in a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] }
      },
      "required": ["id", "studentId", "courseId", "date", "status"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system with RBAC",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["id", "email", "role"]
    }
  },
  "firestore": {
    "/students/{studentId}": { "schema": "Student", "description": "Students collection" },
    "/courses/{courseId}": { "schema": "Course", "description": "Courses collection" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payments collection" },
    "/inventory/{itemId}": { "schema": "Inventory", "description": "Inventory collection" },
    "/inventoryTransactions/{transactionId}": { "schema": "InventoryTransaction", "description": "Inventory transactions collection" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customers collection" },
    "/measurements/{measurementId}": { "schema": "Measurement", "description": "Measurements collection" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance collection" },
    "/users/{userId}": { "schema": "User", "description": "Users collection for RBAC" }
  }
}
