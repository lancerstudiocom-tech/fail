rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "lancerstudio.com@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.courses is list &&
             data.totalFee is number &&
             data.amountPaid is number &&
             data.balance is number &&
             (!('phone' in data) || data.phone is string);
    }

    function isValidCourse(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.fee is number && data.fee >= 0;
    }

    function isValidPayment(data) {
      return data.studentId is string &&
             data.amount is number && data.amount > 0 &&
             data.type in ['credit', 'debit'] &&
             (!('studentName' in data) || data.studentName is string) &&
             (!('method' in data) || data.method is string) &&
             (!('notes' in data) || data.notes is string) &&
             (!('date' in data) || data.date is string) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidInventory(data) {
      return data.name is string && data.name.size() > 0 &&
             data.totalQuantityBought is number &&
             data.quantityRemaining is number &&
             data.costPerItem is number &&
             data.totalCost is number;
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string &&
             data.status in ['Pending', 'Completed', 'Out for Delivery', 'Received'] &&
             data.totalBill is number &&
             data.balance is number;
    }

    function isValidStudentCourse(data) {
      return data.studentId is string &&
             data.courseName is string && data.courseName.size() > 0 &&
             data.amountPaid is number &&
             data.receiptNo is string &&
             data.date is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      hasOnlyAllowedFields(['name', 'email', 'role']) && 
                      request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && 
                      request.resource.data.role == resource.data.role);
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidCourse(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidPayment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidInventory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /inventoryTransactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /measurements/{measurementId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /student_courses/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidStudentCourse(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
